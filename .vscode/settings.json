{
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },
  "[html][django-html][handlebars][hbs][mustache][jinja][jinja-html][nj][njk][nunjucks][twig]": {
    "editor.defaultFormatter": "monosans.djlint",
    "editor.formatOnSave": true
  },
  "djlint.useVenv": true,
  "djlint.useEditorIndentation": false,
  "ruff.enable": true,
  "ruff.importStrategy": "fromEnvironment",
  "ruff.configuration": "${workspaceFolder}/src/web/pyproject.toml",
  "mypy-type-checker.args": [
    "--config-file=${workspaceFolder}/src/web/pyproject.toml"
  ],
  "mypy-type-checker.severity": {
    "error": "Error",
    "note": "Information"
  },
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.diagnosticSeverityOverrides": {
    "reportMissingImports": "none",
    "reportMissingModuleSource": "none"
  },
  "python.analysis.extraPaths": ["${workspaceFolder}/src/web"],
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": ["."],
  "python.testing.cwd": "${workspaceFolder}/src/web",
  "python.defaultInterpreterPath": "${workspaceFolder}/src/web/.venv/bin/python",
  "python.terminal.activateEnvironment": true,
  "python.envFile": "${workspaceFolder}/env.d/web",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.stylelint": "explicit"
    }
  },
  "stylelint.enable": true,
  "stylelint.validate": ["css", "scss"],
  "stylelint.configFile": "${workspaceFolder}/.stylelintrc.json",
  "prettier.enable": true,
  "emmet.includeLanguages": {
    "django-html": "html"
  },
  "eslint.useFlatConfig": true,
  "[vue][typescript][javascript][json][jsonc]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "never"
    }
  },
  "eslint.validate": [
    "javascript",
    "typescript",
    "vue",
    "json",
    "jsonc"
  ]
}
