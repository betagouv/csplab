{
  "name": "csplab-frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "generate-types": "openapi-typescript ../../presentation/static/api/internal-schema.yaml -o src/types/api.d.ts"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^2.0.1",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^2.0.0",
    "@atlaskit/pragmatic-drag-and-drop-live-region": "^2.0.0",
    "@iconify/vue": "^5.0.1",
    "@pinia/colada": "^1.4.2",
    "@sentry/vue": "^10.58.0",
    "@tanstack/vue-table": "^8.21.3",
    "openapi-fetch": "^0.17.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.10",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@iconify-icons/ri": "^1.2.10",
    "@storybook/addon-docs": "^10.4.5",
    "@storybook/vue3": "^10.4.5",
    "@storybook/vue3-vite": "^10.4.5",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.5.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-storybook": "^10.4.5",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "remark-gfm": "^4.0.1",
    "sass": "^1.101.0",
    "storybook": "^10.4.5",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue-component-meta": "^3.3.5",
    "vue-tsc": "^3.3.5"
  }
}
