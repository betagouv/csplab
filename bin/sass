#!/usr/bin/env bash

set -eo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
WEB_DIR="$REPO_ROOT/src/web"
SASS_BIN="$WEB_DIR/node_modules/.bin/sass"

# Configuration
SCSS_DIR="${SCSS_DIR:-$WEB_DIR/presentation/assets/styles}"
CSS_DIR="${CSS_DIR:-$WEB_DIR/presentation/static/css}"
SOURCE_MAP="${SOURCE_MAP:-false}"

# Check if Sass is installed in the web workspace
if [ ! -x "$SASS_BIN" ]; then
    echo "Error: Sass not found in src/web/node_modules. Run 'make frontend-install'." >&2
    exit 1
fi

# Parse command
case "${1:-compile}" in
    compile)
        "$SASS_BIN" "$SCSS_DIR:$CSS_DIR" --no-source-map
        ;;
    watch)
        "$SASS_BIN" "$SCSS_DIR:$CSS_DIR" --watch --no-source-map
        ;;
    *)
        echo "Usage: $0 {compile|watch}" >&2
        exit 1
        ;;
esac
